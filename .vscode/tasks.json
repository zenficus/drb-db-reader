{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"group": "build",
			"type": "dotnet",
			"task": "build",
			"problemMatcher": "$msCompile",
		},
		{
			"label": "clean",
			"group": "build",
			"type": "dotnet",
			"task": "clean",
			"problemMatcher": "$msCompile",
			"hide": true,
		},
		{
			"label": "rebuild",
			"group": "build",
			"dependsOn": ["clean", "build"],
			"dependsOrder": "sequence",
			"problemMatcher": "$msCompile",
		},
		{
			"label": "release-noRuntime",
			"group": "build",
			"type": "process",
			"command": "dotnet",
			"args": ["publish", "-c=Release"],
			"problemMatcher": "$msCompile",
		},
		{
			"label": "release-withRuntime",
			"group": "build",
			"type": "process",
			"command": "dotnet",
			"args": ["publish", "-c=ReleaseWithRuntime"],
			"problemMatcher": "$msCompile",
		},
	]
}
